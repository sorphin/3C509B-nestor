1    85				     ;The following two	macros are used	to manipulate port addresses.
1    86				     ;Use loadport to initialize dx.  Use setport to set a specific port on
1    87				     ;the board.  setport remembers what the current port number is, but beware!
1    88				     ;setport assumes that code	is being executed in the same order as the
1    89				     ;code is presented	in the source file.  Whenever this assumption is violated,
1    90				     ;you need to enter	another	loadport.  Some, but not all examples are:
1    91				     ;in a loop	with multiple setports,	or a backward jump over	a setport, or
1    92				     ;a	forward	jump over a setport.  If you have any doubt, consult the
1    93				     ;individual driver	sources	for examples of	usage.	If you suspect that
1    94				     ;you have too few loadports, define the symbol "no_confidence" to a
1    95				     ;one.  This will force a loadport before every setport.  If you wish to turn
1    96				     ;it off for some of your code, redefine it	to a zero.
1    97
1    98				     loadport	     macro
1    99					     mov     dx,io_addr
1   100				     port_no =	     0
1   101					     endm
1   102
1   103				     ;change the port number from the current value to the new value.
1   104				     setport macro   new_port_no
1   105					     ifdef   no_confidence	     ;define if	you suspect that you don't
1   106					       if    no_confidence
1   107						     loadport		     ;	have enough loadports, i.e. dx is
1   108					       endif
1   109					     endif			     ;	set to the wrong port.
1   110					     if	     new_port_no - port_no EQ 1
1   111						     inc     dx
1   112					     else
1   113						     if	     new_port_no - port_no EQ -1
1   114							     dec     dx
Turbo Assembler	 Version 4.1	    05/31/26 09:03:14	    Page 3
tail.ASM



1   115						     else
1   116							     if	     new_port_no - port_no NE 0
1   117								     add     dx,new_port_no - port_no
1   118							     endif
1   119						     endif
1   120					     endif
1   121				     port_no =	     new_port_no
1   122					     endm
