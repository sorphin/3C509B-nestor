1   189				     send_queueempty macro
1   190				     ; Check if	send queue is empty.
1   191				     ; Enter with interrupts disabled.
1   192				     ; Exit with zr (zero) if empty, nz	(not zero) if not.
1   193				     ; Destroys	ax.
1   194					     mov ax, word ptr send_head	     ; Queue empty?
1   195					     or	ax,  word ptr send_head+2
1   196					     endm
1   197
1   198				     send_peekqueue  macro
1   199				     ; Peek into the queue and get the next entry.
1   200				     ; Enter with interrupts disabled.
1   201				     ; Exit with es:di -> iocb.
1   202					     les di, send_head	     ; Get head	segment:offset
1   203					     endm
1   204
1   205				     print_it	     macro
1   206					     mov	     ah, 9
1   207					     int	     21h
1   208					     endm
