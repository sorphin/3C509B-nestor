1   146				     ;this macro writes	the given character to the given row and column	on
1   147				     ;	an CGA.
1   148				     to_scrn macro   r,	c, ch
1   149					     local   again
1   150					     push    bx
1   151					     push    es
1   152					     mov     bx,0b800h
1   153					     mov     es,bx
1   154					     mov     bx,es:[r*160+c*2]
1   155				     again:
1   156					     inc     bh
1   157					     and     bh,07h
1   158					     je	     again		     ;;	don't use black.
1   159					     mov     bl,ch
1   160					     mov     es:[r*160+c*2],bx
1   161					     pop     es
1   162					     pop     bx
1   163					     endm
