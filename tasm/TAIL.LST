1   124				     ;this macro does a	"rep movsb" with a static count.
1   125				     repmov  macro   count
1   126					     rept    (count) / 2
1   127					     movsw
1   128					     endm
1   129					     rept    (count) MOD 2
1   130					     movsb
1   131					     endm
1   132					     endm
