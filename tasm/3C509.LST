1    91				     ;The following two	macros are used	to manipulate port addresses.
1    92				     ;Use loadport to initialize dx.  Use setport to set a specific port on
1    93				     ;the board.  setport remembers what the current port number is, but beware!
1    94				     ;setport assumes that code	is being executed in the same order as the
1    95				     ;code is presented	in the source file.  Whenever this assumption is violated,
1    96				     ;you need to enter	another	loadport.  Some, but not all examples are:
1    97				     ;in a loop	with multiple setports,	or a backward jump over	a setport, or
1    98				     ;a	forward	jump over a setport.  If you have any doubt, consult the
1    99				     ;individual driver	sources	for examples of	usage.	If you suspect that
1   100				     ;you have too few loadports, define the symbol "no_confidence" to a
1   101				     ;one.  This will force a loadport before every setport.  If you wish to turn
1   102				     ;it off for some of your code, redefine it	to a zero.
1   103
1   104				     loadport	     macro
1   105					     mov     dx,io_addr
1   106				     port_no =	     0
1   107					     endm
1   108
1   109				     ;change the port number from the current value to the new value.
1   110				     setport macro   new_port_no
1   111					     ifdef   no_confidence	     ;define if	you suspect that you don't
1   112					       if    no_confidence
1   113						     loadport		     ;	have enough loadports, i.e. dx is
Turbo Assembler	 Version 4.1	    05/31/26 09:03:11	    Page 3
3c509.ASM



1   114					       endif
1   115					     endif			     ;	set to the wrong port.
1   116					     if	     new_port_no - port_no EQ 1
1   117						     inc     dx
1   118					     else
1   119						     if	     new_port_no - port_no EQ -1
1   120							     dec     dx
1   121						     else
1   122							     if	     new_port_no - port_no NE 0
1   123								     add     dx,new_port_no - port_no
1   124							     endif
1   125						     endif
1   126					     endif
1   127				     port_no =	     new_port_no
1   128					     endm
1   129
1   130				     ;this macro does a	"rep movsb" with a static count.
1   131				     repmov  macro   count
1   132					     rept    (count) / 2
1   133					     movsw
1   134					     endm
1   135					     rept    (count) MOD 2
1   136					     movsb
1   137					     endm
1   138					     endm
1   139
1   140				     ;moves a segment register into another segment register.
1   141				     movseg  macro   to, from
1   142					     push    from
1   143					     pop     to
1   144					     endm
1   145
1   146				     ;add a word to a dword.
1   147				     add2    macro   n,a		     ; inc a 32	bit integer
1   148					     add     n.offs,a		     ;increment	the low	word
1   149					     adc     n.segm,0		     ;increment	the high word
1   150					     endm
1   151
1   152				     ;this macro writes	the given character to the given row and column	on
1   153				     ;	an CGA.
1   154				     to_scrn macro   r,	c, ch
1   155					     local   again
1   156					     push    bx
1   157					     push    es
1   158					     mov     bx,0b800h
1   159					     mov     es,bx
1   160					     mov     bx,es:[r*160+c*2]
1   161				     again:
1   162					     inc     bh
1   163					     and     bh,07h
1   164					     je	     again		     ;;	don't use black.
1   165					     mov     bl,ch
1   166					     mov     es:[r*160+c*2],bx
1   167					     pop     es
1   168					     pop     bx
1   169					     endm
1   170
