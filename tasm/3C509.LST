1   195				     send_queueempty macro
1   196				     ; Check if	send queue is empty.
1   197				     ; Enter with interrupts disabled.
1   198				     ; Exit with zr (zero) if empty, nz	(not zero) if not.
1   199				     ; Destroys	ax.
1   200					     mov ax, word ptr send_head	     ; Queue empty?
1   201					     or	ax,  word ptr send_head+2
1   202					     endm
1   203
1   204				     send_peekqueue  macro
1   205				     ; Peek into the queue and get the next entry.
1   206				     ; Enter with interrupts disabled.
1   207				     ; Exit with es:di -> iocb.
1   208					     les di, send_head	     ; Get head	segment:offset
1   209					     endm
1   210
1   211				     print_it	     macro
1   212					     mov	     ah, 9
1   213					     int	     21h
1   214					     endm
1   215
1   216				     print   macro   message_param
1   217					     mov	     dx, offset	message_param
1   218					     print_it
1   219					     endm
