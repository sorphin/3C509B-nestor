    585					     include timeout.asm
1   586				     ;put into the public domain by Russell Nelson, nelson@crynwr.com
1   587
1   588				     ;we read the timer	chip's counter zero.  It runs freely, counting down
1   589				     ;from 65535 to zero.  We sample the count coming in and subract the previous
1   590				     ;count.  Then we double it	and add	it to our timeout_counter.  When it overflows,
1   591				     ;then we've waited	a tick of 27.5 ms.
1   592
1   593	0031  ????		     timeout	     dw	     ?		     ;number of	ticks to wait.
1   594	0033  ????		     timeout_counter dw	     ?		     ;old counter zero value.
1   595	0035  ????		     timeout_value   dw	     ?
1   596
1   597					     public  set_timeout, do_timeout
1   598	0037			     set_timeout:
1   599				     ;enter with ax = number of	ticks (36.4 ticks per second).
1   600	0037  40			     inc     ax			     ;the first	times out immediately.
1   601	0038  2E: A3 0031r		     mov     cs:timeout,ax
1   602	003C  2E: C7 06	0033r 0000	     mov     cs:timeout_counter,0
1   603	0043  E8 0005			     call    latch_timer
1   604	0046  2E: A3 0035r		     mov     cs:timeout_value,ax
1   605	004A  C3			     ret
1   606
1   607	004B			     latch_timer:
1   608	004B  B0 00			     mov     al,0		     ;latch counter zero.
1   609	004D  E6 43			     out     43h,al
1   610	004F  E4 40			     in	     al,40h		     ;read counter zero.
1   611	0051  8A E0			     mov     ah,al
1   612	0053  E4 40			     in	     al,40h
1   613	0055  86 E0			     xchg    ah,al
1   614	0057  C3			     ret
1   615
1   616
1   617	0058			     do_timeout:
1   618				     ;call at *least* every 27.5ms when	checking for timeout.  Returns nz
1   619				     ;if we haven't timed out yet.
1   620	0058  E8 FFF0			     call    latch_timer
1   621	005B  2E: 87 06	0035r		     xchg    ax,cs:timeout_value
1   622	0060  2E: 2B 06	0035r		     sub     ax,cs:timeout_value
1   623	0065  D1 E0			     shl     ax,1		     ;keep timeout in increments of 27.5 ms.
1   624	0067  2E: 01 06	0033r		     add     cs:timeout_counter,ax   ;has the counter overflowed yet?
1   625	006C  73 06			     jnc     do_timeout_1	     ;no.
1   626	006E  2E: FF 0E	0031r		     dec     cs:timeout		     ;Did we hit the timeout value yet?
