1   128
1   129				     ;this macro writes	the given character to the given row and column	on
1   130				     ;	an CGA.
1   131				     to_scrn macro   r,	c, ch
1   132					     local   again
1   133					     push    bx
1   134					     push    es
1   135					     mov     bx,0b800h
1   136					     mov     es,bx
1   137					     mov     bx,es:[r*160+c*2]
1   138				     again:
1   139					     inc     bh
1   140					     and     bh,07h
1   141					     je	     again		     ;;	don't use black.
1   142					     mov     bl,ch
1   143					     mov     es:[r*160+c*2],bx
1   144					     pop     es
1   145					     pop     bx
1   146					     endm
