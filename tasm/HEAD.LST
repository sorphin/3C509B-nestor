   1238				     ;
   1239				     ; I have had a problem with some hardware which under extreme LAN loading
   1240				     ; conditions will re-enter	the recv_isr. Since the	8259 interrupts	for
   1241				     ; the card	are masked off,	and the	card's interrupt mask register is
   1242				     ; cleared (in 8390.asm at least) disabling	the card from interrupting, this
   1243				     ; is clearly a hardware problem. Due to the low frequencey	of occurance, and
   1244				     ; extreme conditions under	which this happens, it is not lilely to	be fixed
   1245				     ; in hardware any time soon, plus retrofitting of hardware	in the field will
   1246				     ; not happen. To protect the driver from the adverse effects of this I am
   1247				     ; adding a	simple re-entrancy trap	here.  - gft - 910617
   1248				     ;
   1249
   1250	08AF  00		     in_recv_isr     db	     0	     ; flag to trap re-entrancy
   1251
   1252	08B0			     recv_isr:
   1253	08B0  2E: 80 3E	08AFr 00	     cmp     in_recv_isr, 0
   1254	08B6  75 64			     jne     recv_iret
Turbo Assembler	 Version 4.1	    06/02/26 07:01:08	    Page 23
head.ASM



   1255
   1256	08B8  2E: C6 06	08AFr 01	     mov     in_recv_isr, 1
   1257
   1258				     ; I realize this re-entrancy trap is not perfect, you could be re-entered
   1259				     ; anytime before the above	instruction. However since the stacks have not
   1260				     ; been swapped re-entrancy	here will only appear to be a spurious interrupt.
   1261				     ; - gft - 910617
   1262
   1263				     ; In order	to achieve back-to-back	packet transmissions, we handle	the
   1264				     ; latency-critical	portion	of transmit interrupts first.  The xmit
   1265				     ; interrupt routine should	only start the next transmission, but do
   1266				     ; no other	work.  It may only touch ax and	dx (the	only register necessary
   1267				     ; for doing "out" instructions) unless it first pushes any	other registers
   1268				     ; itself.
   1269	08BE  50			     push    ax
   1270	08BF  52			     push    dx
   1271	08C0  E8 0000e			     call    xmit
   1272
   1273				     ; Now switch stacks, push remaining registers, and	do remaining interrupt work.
   1274	08C3  1E			     push    ds
   1275	08C4  8C C8			     mov     ax,cs		     ;ds = cs.
   1276	08C6  8E D8			     mov     ds,ax
