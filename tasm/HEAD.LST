   1293				     ; The following comment is	wrong in that we now do	a specific EOI command,
   1294				     ; and because we don't enable interrupts (even though we should).
   1295
   1296				     ; Chips & Technologies 8259 clone chip seems to be	very broken.  If you
   1297				     ; send it a Non Specific EOI command, it clears all In Service Register
   1298				     ; bits instead of just the	one with the highest priority (as the Intel
   1299				     ; chip does and clones should do).	 This bug causes our interrupt
   1300				     ; routine to be reentered if: 1. we reenable processor interrupts;
   1301				     ; 2. we reenable device interrupts; 3. a timer or other higher priority
   1302				     ; device interrupt	now comes in; 4. the new interrupting device uses
   1303				     ; a Non Specific EOI; 5. our device interrupts again.  Because of
   1304				     ; this bug, we now	completely mask	our interrupts around the call
   1305				     ; to "recv", the real device interrupt handler.  This allows us
   1306				     ; to send an EOI instruction to the 8259 early, before we actually
   1307				     ; reenable	device interrupts.  Since the interrupt	is masked, we
   1308				     ; are still guaranteed not	to get another interrupt from our device
   1309				     ; until the interrupt handler returns.  This has another benefit:
   1310				     ; we now no longer	prevent	other devices from interrupting	while our
   1311				     ; interrupt handler is running.  This is especially useful	if we have
Turbo Assembler	 Version 4.1	    06/02/26 07:01:08	    Page 24
head.ASM



   1312				     ; other (multiple)	packet drivers trying to do low-latency	transmits.
   1313	08DC  A0 0000e			     mov     al,int_no	     ; Disable further device interrupts
   1314	08DF  E8 0077			     call    maskint
   1315
   1316				     ; The following is	from Bill Rust,	<wjr@ftp.com>
   1317				     ; this code dismisses the interrupt at the	8259. if the interrupt number
   1318				     ;	is > 8 then it requires	fondling two PICs instead of just one.
   1319	08E2  A0 0000e			     mov     al, int_no	     ; get hardware int	#
   1320	08E5  0A C0			     or	     al,al	     ; if it's zero, then there	is no IRQ to ack.
   1321	08E7  74 12			     je	     recv_isr_3	     ; so skip the EOI processing.
   1322	08E9  3C 08			     cmp     al, 8	     ; see if its on secondary PIC
   1323	08EB  7F 06			     jg	     recv_isr_4
   1324	08ED  04 60			     add     al, 60h	     ; make specific EOI dismissal
   1325	08EF  E6 20			     out     20h, al
   1326	08F1  EB 08			     jmp     short recv_isr_3	     ; all done
   1327	08F3			     recv_isr_4:
