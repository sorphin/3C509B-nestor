1    67
1    68				     ;The following two	macros are used	to manipulate port addresses.
1    69				     ;Use loadport to initialize dx.  Use setport to set a specific port on
1    70				     ;the board.  setport remembers what the current port number is, but beware!
1    71				     ;setport assumes that code	is being executed in the same order as the
1    72				     ;code is presented	in the source file.  Whenever this assumption is violated,
1    73				     ;you need to enter	another	loadport.  Some, but not all examples are:
1    74				     ;in a loop	with multiple setports,	or a backward jump over	a setport, or
1    75				     ;a	forward	jump over a setport.  If you have any doubt, consult the
1    76				     ;individual driver	sources	for examples of	usage.	If you suspect that
1    77				     ;you have too few loadports, define the symbol "no_confidence" to a
1    78				     ;one.  This will force a loadport before every setport.  If you wish to turn
1    79				     ;it off for some of your code, redefine it	to a zero.
1    80
1    81				     loadport	     macro
1    82					     mov     dx,io_addr
1    83				     port_no =	     0
1    84					     endm
1    85
1    86				     ;change the port number from the current value to the new value.
1    87				     setport macro   new_port_no
1    88					     ifdef   no_confidence	     ;define if	you suspect that you don't
1    89					       if    no_confidence
1    90						     loadport		     ;	have enough loadports, i.e. dx is
1    91					       endif
1    92					     endif			     ;	set to the wrong port.
1    93					     if	     new_port_no - port_no EQ 1
1    94						     inc     dx
1    95					     else
1    96						     if	     new_port_no - port_no EQ -1
1    97							     dec     dx
1    98						     else
1    99							     if	     new_port_no - port_no NE 0
1   100								     add     dx,new_port_no - port_no
1   101							     endif
1   102						     endif
1   103					     endif
1   104				     port_no =	     new_port_no
1   105					     endm
1   106
1   107				     ;this macro does a	"rep movsb" with a static count.
1   108				     repmov  macro   count
1   109					     rept    (count) / 2
1   110					     movsw
1   111					     endm
1   112					     rept    (count) MOD 2
1   113					     movsb
1   114					     endm
