1   172				     send_queueempty macro
1   173				     ; Check if	send queue is empty.
1   174				     ; Enter with interrupts disabled.
1   175				     ; Exit with zr (zero) if empty, nz	(not zero) if not.
1   176				     ; Destroys	ax.
1   177					     mov ax, word ptr send_head	     ; Queue empty?
1   178					     or	ax,  word ptr send_head+2
1   179					     endm
1   180
1   181				     send_peekqueue  macro
1   182				     ; Peek into the queue and get the next entry.
1   183				     ; Enter with interrupts disabled.
1   184				     ; Exit with es:di -> iocb.
1   185					     les di, send_head	     ; Get head	segment:offset
1   186					     endm
1   187
1   188				     print_it	     macro
1   189					     mov	     ah, 9
1   190					     int	     21h
1   191					     endm
1   192
1   193				     print   macro   message_param
1   194					     mov	     dx, offset	message_param
1   195					     print_it
1   196					     endm
