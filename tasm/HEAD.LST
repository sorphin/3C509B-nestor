1   172				     ; Exit with zr (zero) if empty, nz	(not zero) if not.
1   173				     ; Destroys	ax.
1   174					     mov ax, word ptr send_head	     ; Queue empty?
1   175					     or	ax,  word ptr send_head+2
1   176					     endm
1   177
1   178				     send_peekqueue  macro
1   179				     ; Peek into the queue and get the next entry.
1   180				     ; Enter with interrupts disabled.
1   181				     ; Exit with es:di -> iocb.
1   182					     les di, send_head	     ; Get head	segment:offset
1   183					     endm
